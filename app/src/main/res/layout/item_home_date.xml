<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="60dp"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/tvWeekday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/coffee_text_muted"
        android:textSize="13sp" />

    <FrameLayout
        android:id="@+id/layoutDateContainer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:foregroundGravity="center">

        <TextView
            android:id="@+id/tvDayOfMonth"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/coffee_text"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <View
        android:id="@+id/viewIndicator"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_home_date_dot"
        android:visibility="gone" />
</LinearLayout>
